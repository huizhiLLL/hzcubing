# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/hzcubing

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d

# Server Configuration
PORT=3001
